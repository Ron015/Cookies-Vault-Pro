{
  "manifest_version": 3,
  "name": "Ron Cookie Vault Pro",
  "version": "2.1.0",
  "description": "Multi-account cookie manager with cloud sync",
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "activeTab",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ron Cookie Vault Pro"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}